# =========================================================
# 1. ORIGEN DE DATOS - PRODUCCION (SQL Server)
# Usuario con rol db_datareader (Solo Lectura)
# =========================================================
SQLSERVER_HOST=192.168.X.X
SQLSERVER_PORT=1433
SQLSERVER_USER=usuario_sqlserver_lectura
SQLSERVER_PASSWORD=contrasena_sqlserver

# =========================================================
# 2. ORIGEN DE DATOS - TESTING (MySQL Simulator)
# Usado cuando ejecutas con el flag --testing
# =========================================================
DB_HOST_TEST=localhost
DB_PORT_TEST=3306
DB_USER_TEST=usuario_mysql_test
DB_PASSWORD_TEST=contrasena_mysql_test
DB_NAME_TEST=nombre_base_datos_test

# =========================================================
# 3. DESTINO - GOOGLE SHEETS
# =========================================================
# Produccion
SPREADSHEET_ID=id_de_tu_documento_google_sheets_prod
SHEET_NAME=Hoja 1

# Testing (Obligatorio en --testing)
SPREADSHEET_ID_TEST=id_de_tu_documento_google_sheets_test

# Autenticacion API
GOOGLE_CREDENTIALS_FILE=credentials.json

# =========================================================
# 4. BASE DE AUDITORIA - PRODUCCION (MySQL)
# Usada por core/db_utils.py en ejecucion normal
# =========================================================
AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=3306
AUDIT_DB_USER=usuario_auditoria_prod
AUDIT_DB_PASSWORD=contrasena_auditoria_prod
AUDIT_DB_NAME=auditoria_prod
AUDIT_DB_CONNECTION_TIMEOUT=10
AUDIT_DB_CHARSET=utf8mb4
AUDIT_DB_COLLATION=utf8mb4_unicode_ci

# =========================================================
# 5. BASE DE AUDITORIA - TESTING (MySQL)
# Usada por core/db_utils.py con flag --testing
# =========================================================
AUDIT_DB_HOST_TEST=localhost
AUDIT_DB_PORT_TEST=3306
AUDIT_DB_USER_TEST=usuario_auditoria_test
AUDIT_DB_PASSWORD_TEST=contrasena_auditoria_test
AUDIT_DB_NAME_TEST=auditoria_test
AUDIT_DB_CONNECTION_TIMEOUT_TEST=10
AUDIT_DB_CHARSET_TEST=utf8mb4
AUDIT_DB_COLLATION_TEST=utf8mb4_unicode_ci