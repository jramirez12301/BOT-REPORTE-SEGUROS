# =========================
# Fuente de datos - PRODUCCION
# =========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASSWORD=contrasena_mysql
DB_NAME=nombre_base_datos_prod

# =========================
# Fuente de datos - TESTING
# Nota: DB_NAME_TEST y SPREADSHEET_ID_TEST son obligatorios en --testing.
# Se recomienda definir tambien HOST/PORT/USER/PASSWORD de testing para aislamiento total.
# =========================
DB_HOST_TEST=localhost
DB_PORT_TEST=3306
DB_USER_TEST=usuario_mysql_test
DB_PASSWORD_TEST=contrasena_mysql_test
DB_NAME_TEST=nombre_base_datos_test

# =========================
# Google Sheets - PRODUCCION
# =========================
SPREADSHEET_ID=id_de_tu_documento_google_sheets_prod
SHEET_NAME=Hoja 1

# =========================
# Google Sheets - TESTING
# =========================
SPREADSHEET_ID_TEST=id_de_tu_documento_google_sheets_test

# Base de auditoria - PRODUCCION
# Usada por core/db_utils.py cuando AuditLogger corre con env="PROD"
# =========================
AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=3306
AUDIT_DB_USER=usuario_auditoria
AUDIT_DB_PASSWORD=contrasena_auditoria
AUDIT_DB_NAME=auditoria_prod
AUDIT_DB_CONNECTION_TIMEOUT=10
AUDIT_DB_CHARSET=utf8mb4
AUDIT_DB_COLLATION=utf8mb4_unicode_ci

# =========================
# Base de auditoria - TESTING
# Usada por core/db_utils.py cuando AuditLogger corre con env="TEST"
# =========================
AUDIT_DB_HOST_TEST=localhost
AUDIT_DB_PORT_TEST=3306
AUDIT_DB_USER_TEST=usuario_auditoria_test
AUDIT_DB_PASSWORD_TEST=contrasena_auditoria_test
AUDIT_DB_NAME_TEST=auditoria_test
AUDIT_DB_CONNECTION_TIMEOUT_TEST=10
AUDIT_DB_CHARSET_TEST=utf8mb4
AUDIT_DB_COLLATION_TEST=utf8mb4_unicode_ci
